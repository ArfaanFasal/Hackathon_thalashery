# Optional: OpenAI for intent/scam JSON, conversational polish, Whisper STT + English normalization
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Speed: CIVIC_POLISH=0 (default) skips an extra LLM pass on every reply. CIVIC_FAST_OPENING=1 skips greeting LLM.
# TRANSCRIBE_TRANSLATE=1 adds a second LLM step after Whisper to force English (slower; omit for English-only STT).
CIVIC_POLISH=0
CIVIC_FAST_OPENING=1
TRANSCRIBE_TRANSLATE=0

# Optional: MongoDB Atlas for chat sessions + messages (falls back to local SQLite if unset or unreachable)
MONGODB_URI=
MONGO_DB_NAME=civicsafe